# ─── Base de Datos ───────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:PORT/pichangaya_db

# ─── JWT ─────────────────────────────────────────────────────
SECRET_KEY=cambia-esta-clave-por-una-segura-de-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── App ─────────────────────────────────────────────────────
APP_NAME=PichangaYa API
DEBUG=True
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ─── Cloudinary (almacenamiento de vouchers/imágenes) ────────
CLOUDINARY_CLOUD_NAME=tu-cloud-name
CLOUDINARY_API_KEY=tu-api-key
CLOUDINARY_API_SECRET=tu-api-secret

# ─── Nubefact / SUNAT ────────────────────────────────────────
NUBEFACT_TOKEN=tu-token-nubefact
NUBEFACT_URL=https://api.nubefact.com/api/v1

# ─── Empresa (para comprobantes) ─────────────────────────────
EMPRESA_RUC=20123456789
EMPRESA_RAZON_SOCIAL=PICHANGAYA SAC
EMPRESA_DIRECCION=Av. Revolución 1250, Collique, Lima

# ─── Firebase (push notifications) ──────────────────────────
FCM_SERVER_KEY=tu-fcm-server-key
