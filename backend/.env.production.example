# ══════════════════════════════════════════════════════════════
# VARIABLES DE ENTORNO — PRODUCCIÓN (Railway)
# Copiar estos valores al panel de Railway > Variables
# ══════════════════════════════════════════════════════════════

# ── Base de datos ─────────────────────────────────────────────
# Railway la genera automáticamente al conectar el plugin PostgreSQL
DATABASE_URL=postgresql+asyncpg://...  # Railway lo asigna solo

# ── Seguridad ──────────────────────────────────────────────────
SECRET_KEY=<mínimo 32 chars aleatorios — usar: python -c "import secrets; print(secrets.token_hex(32))">
DEBUG=False

# ── CORS ───────────────────────────────────────────────────────
# Agregar aquí el dominio real de la web app cuando se despliegue
# Por ahora solo Railway (el backend no necesita su propia URL en CORS)
ALLOWED_ORIGINS=https://pichangaya-production-0eb7.up.railway.app

# ── Servicios externos ─────────────────────────────────────────
IMGBB_API_KEY=36eaed76952b26c5c35263e22ae8597c
YAPE_NUMERO=993592328

# ── Facturación electrónica (SUNAT/Nubefact) ──────────────────
NUBEFACT_TOKEN=
NUBEFACT_URL=https://api.nubefact.com/api/v1
EMPRESA_RUC=
EMPRESA_RAZON_SOCIAL=
EMPRESA_DIRECCION=

# ── Firebase ───────────────────────────────────────────────────
# El JSON del service account debe subirse como variable de entorno
# en Railway (pegar el contenido del JSON como string)
FIREBASE_SERVICE_ACCOUNT_JSON=firebase-service-account.json
